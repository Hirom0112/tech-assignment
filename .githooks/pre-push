#!/usr/bin/env bash
#
# Pre-push hook (CLAUDE.md §4 — enforced-trunk model).
#
# Runs the full check suite for changed packages before any push: TypeScript
# typecheck (tsc --noEmit) + the package's test suite. A failing check blocks
# the push. Never bypass with --no-verify; fix the code, not the hook.
#
# Wire it once per clone:  git config core.hooksPath .githooks
#
# Scope: serverless-v2/services/streaks-api (S0) and
# serverless-v2/services/streaks-frontend (joined S6, guarded S10).
#
# Each package runs the SAME commands its CI job runs (CLAUDE.md §4 parity —
# red CI == red push):
#   streaks-api      → npm run typecheck (tsc --noEmit) + npm test (jest)
#   streaks-frontend → npm run build (tsc && vite build, the TS check) + npm test (vitest)
# The frontend has no `typecheck` script, so its TS check is `npm run build`.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Packages guarded by this hook (path relative to repo root). The matching
# entry in TS_CHECK is the package's TypeScript-check script (`tsc --noEmit`
# for the api, `build` = `tsc && vite build` for the frontend).
PACKAGES=(
  "serverless-v2/services/streaks-api"
  "serverless-v2/services/streaks-frontend"
)
TS_CHECK=(
  "typecheck"
  "build"
)

# Files staged/committed for this push, relative to repo root.
CHANGED="$(git diff --name-only HEAD @{push} 2>/dev/null || git diff --name-only HEAD)"

for i in "${!PACKAGES[@]}"; do
  pkg="${PACKAGES[$i]}"
  ts_script="${TS_CHECK[$i]}"

  # Only run the suite if this push touches the package.
  if ! printf '%s\n' "$CHANGED" | grep -q "^$pkg/"; then
    echo "pre-push: no changes in $pkg — skipping its checks."
    continue
  fi

  echo "pre-push: checking $pkg ..."
  (
    cd "$REPO_ROOT/$pkg"
    echo "  -> npm run $ts_script"
    npm run "$ts_script"
    echo "  -> npm test"
    npm test
  )
done

echo "pre-push: all package checks passed."
