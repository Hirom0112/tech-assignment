#!/usr/bin/env bash
#
# Pre-push hook (CLAUDE.md §4 — enforced-trunk model).
#
# Runs the full check suite for changed packages before any push: TypeScript
# typecheck (tsc --noEmit) + the package's test suite. A failing check blocks
# the push. Never bypass with --no-verify; fix the code, not the hook.
#
# Wire it once per clone:  git config core.hooksPath .githooks
#
# Scope for S0: serverless-v2/services/streaks-api. Extend the PACKAGES list
# as later slices add packages (e.g. streaks-frontend).
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Packages guarded by this hook (path relative to repo root).
PACKAGES=("serverless-v2/services/streaks-api")

# Files staged/committed for this push, relative to repo root.
CHANGED="$(git diff --name-only HEAD @{push} 2>/dev/null || git diff --name-only HEAD)"

for pkg in "${PACKAGES[@]}"; do
  # Only run the suite if this push touches the package.
  if ! printf '%s\n' "$CHANGED" | grep -q "^$pkg/"; then
    echo "pre-push: no changes in $pkg — skipping its checks."
    continue
  fi

  echo "pre-push: checking $pkg ..."
  (
    cd "$REPO_ROOT/$pkg"
    echo "  -> npm run typecheck"
    npm run typecheck
    echo "  -> npm test"
    npm test
  )
done

echo "pre-push: all package checks passed."
