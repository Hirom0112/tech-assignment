# Streaks dashboard local config — copy to `.env`.
# Backend base URL (RTK Query prepends /api/v1/player/streaks).
VITE_API_URL=http://localhost:5001
# Optional demo override: pin the heat-map month. The seeded player
# `streak-001` shows all 5 heat-map states in 2026-04. Leave unset to
# default the calendar to the current UTC month.
VITE_DEMO_MONTH=2026-04
