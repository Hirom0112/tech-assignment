{
  "name": "@hijack/streaks-api",
  "version": "1.0.0",
  "private": true,
  "description": "Streaks API — Serverless Lambda with Express",
  "scripts": {
    "start": "npx serverless offline --config serverless.offline.yml --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/lib-dynamodb": "^3.500.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "luxon": "^3.4.0",
    "mysql2": "^3.9.0",
    "sequelize": "^6.37.0",
    "serverless": "^3.39.0",
    "serverless-http": "^3.2.0",
    "serverless-offline": "^13.3.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.4.0",
    "jest": "^29.7.0",
    "serverless-esbuild": "^1.55.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
